<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Prova.Views.CepView"
             Title="CepView">
    <VerticalStackLayout>
        <Label
              Text="Cep" VerticalTextAlignment="Center"/>

        <Entry
              x:Name="CepEntry"
              Placeholder="Cep"
              Keyboard="Numeric"
              IsEnabled="False"
                />

        <Label
                Text="Cep" VerticalTextAlignment="Center"/>

        <Entry
                x:Name="CepEntry2"
                Placeholder="Digite aqui o Cep"
                Keyboard="Numeric"
                WidthRequest="350"/>
    </VerticalStackLayout>
</ContentPage>